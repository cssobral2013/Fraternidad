featurePrefixes = (
{
code = "###
# OpenType Layout feature definitions
# Format: Adobe FDK for OpenType (AFDKO) version 2.5
# Generated on: 2023-6-23 19:4
# Generated by: FontLab 8.0.0
# Font PostScript name: Fraternidad-Regular
# Font copyright: Copyright (c) 2020 Wayne ShihCopyright (c) 2021 Ravid BalalievCopyright (c) 2021-2023 The Fraternidad Project Authors (https://github.com/cssobral2013/fraternidad)
#
# Totals:
# Languagesystems: 12
# GSUB lookups: 29
# GSUB features: 14 (aalt, calt, case, dnom, frac, liga, locl, numr, ordn, pnum, sinf, subs, sups, tnum)
# GPOS lookups: 1
# GPOS features: 1 (kern)

#
# Languagesystem definitions
#

languagesystem DFLT dflt; # Default default
languagesystem latn dflt; # Latin default
languagesystem latn AZE ; # Latin Azerbaijani
languagesystem latn CRT ; # Latin Crimean Tatar
languagesystem latn KAZ ; # Latin Kazakh
languagesystem latn MOL ; # Latin Moldavian
languagesystem latn ROM ; # Latin Romanian
languagesystem latn TAT ; # Latin Tatar
languagesystem latn TRK ; # Latin Turkish
languagesystem cyrl dflt; # Cyrillic default
languagesystem cyrl BGR ; # Cyrillic Bulgarian
languagesystem cyrl SRB ; # Cyrillic Serbian

#
# Lookup definitions
#

lookup ordn_2 {
# GSUB lookup 3, type 11 (Single)
  sub [A O a o] by [ordfeminine ordmasculine ordfeminine ordmasculine];
} ordn_2;

lookup calt_2 {
# GSUB lookup 4, type 11 (Single)
  sub @calt by @calt2;
} calt_2;

lookup calt_3 {
# GSUB lookup 5, type 11 (Single)
  sub @calt3 by @calt4;
} calt_3;

lookup calt_4 {
# GSUB lookup 6, type 11 (Single)
  sub @calt5 by @calt6;
} calt_4;

lookup calt_5 {
# GSUB lookup 7, type 11 (Single)
  sub @calt5 by @calt6;
} calt_5;


#
# Feature definitions
#
";
tag = Languagesystems;
}
);
features = (
{
code = "# GSUB feature: Access All Alternates
# Lookups: 2

  sub @aalt by @aalt2;
  sub zero.ss01 from [zero.tf.ss01 zero.inferior.ss01 zero.superior.ss01];
  sub one.ss01 from [one.tf.ss01 one.inferior.ss01 onesuperior.ss01];
  sub two.ss01 from [two.tf.ss01 two.inferior.ss01 twosuperior.ss01];
  sub three.ss01 from [three.tf.ss01 three.inferior.ss01 threesuperior.ss01];
  sub four.ss01 from [four.tf.ss01 four.inferior.ss01 four.superior.ss01];
  sub five.ss01 from [five.tf.ss01 five.inferior.ss01 five.superior.ss01];
  sub six.ss01 from [six.tf.ss01 six.inferior.ss01 six.superior.ss01];
  sub seven.ss01 from [seven.tf.ss01 seven.inferior.ss01 seven.superior.ss01];
  sub eight.ss01 from [eight.tf.ss01 eight.inferior.ss01 eight.superior.ss01];
  sub nine.ss01 from [nine.tf.ss01 nine.inferior.ss01 nine.superior.ss01];
  sub zero.tf.ss01 from [zero.ss01];
  sub one.tf.ss01 from [one.ss01];
  sub two.tf.ss01 from [two.ss01];
  sub three.tf.ss01 from [three.ss01];
  sub four.tf.ss01 from [four.ss01];
  sub five.tf.ss01 from [five.ss01];
  sub six.tf.ss01 from [six.ss01];
  sub seven.tf.ss01 from [seven.ss01];
  sub eight.tf.ss01 from [eight.ss01];
  sub nine.tf.ss01 from [nine.ss01];";
tag = aalt;
},
{
code = "# GSUB feature: Localized Forms
# Lookups: 9

  script latn; # Latin
    language AZE ; # Azerbaijani
    sub i by i.loclTRK;

    language TRK ; # Turkish
    sub i by i.loclTRK;

    language MOL ; # Moldavian
    sub [Scedilla scedilla Tcedilla tcedilla] by [Scommaaccent scommaaccent Tcommaaccent tcommaaccent];

    language ROM ; # Romanian
    sub [Scedilla scedilla Tcedilla tcedilla] by [Scommaaccent scommaaccent Tcommaaccent tcommaaccent];

    language TAT ; # Tatar
    sub i by i.loclTRK;

    language CRT ; # Crimean Tatar
    sub i by i.loclTRK;

    language KAZ ; # Kazakh
    sub i by i.loclTRK;


  script cyrl; # Cyrillic
    language SRB ; # Serbian
    sub becyr by becyr.loclSRB;

    language BGR ; # Bulgarian
    sub @locl by @locl2;";
tag = locl;
},
{
code = "# GSUB feature: Subscript
# Lookups: 1

  sub @calt_dnom_numr_ordn_sinf_subs_sups by @dnom_sinf_subs;";
tag = subs;
},
{
code = "# GSUB feature: Scientific Inferiors
# Lookups: 1

  sub @calt_dnom_numr_ordn_sinf_subs_sups by @dnom_sinf_subs;";
tag = sinf;
},
{
code = "# GSUB feature: Superscript
# Lookups: 1

  sub @calt_dnom_numr_ordn_sinf_subs_sups by @numr_sups;";
tag = sups;
},
{
code = "# GSUB feature: Numerators
# Lookups: 1

  sub @calt_dnom_numr_ordn_sinf_subs_sups by @numr_sups;";
tag = numr;
},
{
code = "# GSUB feature: Denominators
# Lookups: 1

  sub @calt_dnom_numr_ordn_sinf_subs_sups by @dnom_sinf_subs;";
tag = dnom;
},
{
code = "# GSUB feature: Fractions
# Lookups: 1

  sub one slash two by onehalf;
  sub one slash four by onequarter;
  sub three slash four by threequarters;
  sub one.ss01 slash two.ss01 by onehalf.ss01;
  sub one.ss01 slash four.ss01 by onequarter.ss01;
  sub three.ss01 slash four.ss01 by threequarters.ss01;
 
  sub @calt_dnom_numr_ordn_sinf_subs_sups by @numr_sups;  
  sub @numr_sups slash' by fraction;
  sub @numr_sups fraction @numr_sups' by @dnom_sinf_subs;";
tag = frac;
},
{
code = "# GSUB feature: Ordinals
# Lookups: 2

  sub @calt_dnom_numr_ordn_sinf_subs_sups [A a]' lookup ordn_2;
  sub @calt_dnom_numr_ordn_sinf_subs_sups [O o]' lookup ordn_2;
  sub N o period by numero;";
tag = ordn;
},
{
code = "# GSUB feature: Proportional Figures
# Lookups: 1

  sub @pnum_tnum2 by @pnum_tnum;";
tag = pnum;
},
{
code = "# GSUB feature: Tabular Figures
# Lookups: 1

  sub @pnum_tnum by @pnum_tnum2;";
tag = tnum;
},
{
code = "# GSUB feature: Case-Sensitive Forms
# Lookups: 1

  sub @case by @case2;";
tag = case;
},
{
code = "# GSUB feature: Standard Ligatures
# Lookups: 1


  lookup liga {
  # GSUB lookup 28, type 14 (Ligature)
    lookupflag IgnoreMarks;
    sub space less [three three.ss01] space by space_less_three_space.liga;
    sub parenleft greater parenright by prnleft_grtr_prnright.liga;
    sub parenleft c parenright by parenleft_c_parenright.liga;
    sub hyphen hyphen by hyphen_hyphen.liga;
    sub hyphen greater by hyphen_greater.liga;
    sub less hyphen by less_hyphen.liga;
    sub f f i by f_f_i;
    sub f f l by f_f_l;
    sub f f by f_f;
    sub f i by fi;
    sub f l by fl;
  } liga;";
tag = liga;
},
{
