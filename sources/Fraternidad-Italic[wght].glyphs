},
{
code = "# GSUB feature: Fractions
# Lookups: 1

  sub one slash two by onehalf;
  sub one slash four by onequarter;
  sub three slash four by threequarters;
  sub one.ss01 slash two.ss01 by onehalf.ss01;
  sub one.ss01 slash four.ss01 by onequarter.ss01;
  sub three.ss01 slash four.ss01 by threequarters.ss01;

  sub @calt_dnom_numr_ordn_sinf_subs_sups by @numr_sups;  
  sub @numr_sups slash' by fraction;
  sub @numr_sups fraction @numr_sups' by @dnom_sinf_subs;";
tag = frac;
},
{
code = "# GSUB feature: Ordinals
# Lookups: 2

  sub @calt_dnom_numr_ordn_sinf_subs_sups [A a]' by [ordfeminine ordfeminine];
  sub @calt_dnom_numr_ordn_sinf_subs_sups [O o]' by [ordmasculine ordmasculine];
  sub N o period by numero;";
tag = ordn;
},
